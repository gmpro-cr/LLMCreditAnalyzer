{
  "installCommand": "cd frontend && npx -y pnpm@9.15.4 install --no-frozen-lockfile",
  "buildCommand": "cd frontend && npx -y pnpm@9.15.4 --filter @workspace/creditguard build",
  "outputDirectory": "frontend/artifacts/creditguard/dist/public",
  "framework": null,
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }]
}

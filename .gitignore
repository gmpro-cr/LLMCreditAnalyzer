# ── Dependencies ──────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.*
.pnpm-store/
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Build output ──────────────────────────────────────────────────────────
dist/
build/
out/
out-tsc/
/.next/
*.tsbuildinfo
next-env.d.ts
.vite/

# ── Python ────────────────────────────────────────────────────────────────
python-service/venv/
**/__pycache__/
*.pyc
python-service/.env

# ── Env files ─────────────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Replit / tooling junk (from the Vite monorepo) ────────────────────────
.local/
.cache/
.expo/
.expo-shared/
.sass-cache/
coverage/

# ── Editors / OS ──────────────────────────────────────────────────────────
.vscode/*
!.vscode/settings.json
.idea/
.DS_Store
Thumbs.db
*.pem

# ── Logs ──────────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Vercel ────────────────────────────────────────────────────────────────
.vercel

# ── SQLite (local dev DB) ─────────────────────────────────────────────────
*.db
*.db-shm
*.db-wal

# ── Local archives (kept out of git; recoverable backups) ─────────────────
frontend-repo-history.bundle
